# DocsForge Environment Configuration

# OpenAI-compatible API endpoint (required)
OPENAI_BASE_URL=http://127.0.0.1:20128/v1

# API key (required even for local endpoints)
OPENAI_API_KEY=your-api-key-here

# Model to use for all agents (default: kr/claude-sonnet-4.5)
MIMO_MODEL=kr/claude-sonnet-4.5

# SQLite cache database path (optional)
DOCSFORGE_DB=~/.docsforge/cache.db
